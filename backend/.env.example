# LLM 接入配置（复制为 .env 后填写真实值；.env 不进 Git）
# 未填 LLM_API_KEY / LLM_BASE_URL 时，后端自动走 mock_outputs 兜底，行为与未接 LLM 时一致。
# 字段经 pydantic-settings 大小写不敏感读取：LLM_API_KEY <-> llm_api_key。

# API key（明文只放在 .env，绝不进被跟踪文件）
LLM_API_KEY=

# 完整 base path（SDK 在其后拼 /chat/completions，不自动加 /v1）。
# 学校 GLM 代理 / 智谱官方 / 通义 / 豆包 / DeepSeek 均为 OpenAI 兼容，填各自完整路径：
#   智谱 GLM:  https://open.bigmodel.cn/api/paas/v4
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
#   豆包:      https://ark.cn-beijing.volces.com/api/v3
#   DeepSeek:  https://api.deepseek.com
# 无尾斜杠。
LLM_BASE_URL=

# 模型名
LLM_MODEL=glm-5.2

# 单请求超时（秒）；防线程池被长调用占满
LLM_TIMEOUT=30

# 代理是否支持 OpenAI response_format={"type":"json_object"}。
# 学校代理若不支持可设 false，后端走防御式解析兜底。
LLM_SUPPORTS_JSON_MODE=true

# ---------------------------------------------------------------------------
# 豆包 Seedream 生图配置（火山方舟 Ark；与上面的 LLM_* 相互独立）
# ---------------------------------------------------------------------------
# 生图走豆包 Seedream（doubao-seedream-5-0-pro-260628），图内渲染中文知识文字。
# 与 LLM_* 不共用：当前 LLM_* 多半指向 DeepSeek，不覆盖 Ark /images/generations，
# 故生图必须独立填 IMAGE_* 指向火山方舟 Ark。
# 未填 IMAGE_API_KEY / IMAGE_BASE_URL 时，生图接口走 fallback（不白屏）。
# 字段经 pydantic-settings 大小写不敏感读取：IMAGE_API_KEY <-> image_api_key。

# ARK API Key（ark- 开头）。火山方舟控制台开通 doubao-seedream-5-0-pro 模型后取。
# 需在「模型激活」页关闭"安全体验模式"的推理限额，否则 429 SetLimitExceeded。
IMAGE_API_KEY=

# Ark OpenAI 兼容端点（SDK 在其后拼 /images/generations）
#   方舟官方: https://ark.cn-beijing.volces.com/api/v3
IMAGE_BASE_URL=

# 模型名（也可填推理接入点 id，如 ep-2024xxxxxxx-xxxxx）
IMAGE_MODEL=doubao-seedream-5-0-pro-260628

# 输出尺寸：Ark 用档位字符串（2K / 1K），不是 1024x1024
IMAGE_SIZE=2K

# 质量档：Seedream 无此参数，留空（Ark 忽略）。保留字段兼容历史。
IMAGE_QUALITY=

# 单请求超时（秒）；Seedream pro 2K 出图偏慢（首图常 >90s），超时也计费故给足 300s
IMAGE_TIMEOUT=300


# ---------------------------------------------------------------------------
# CORS（上线收紧；与 LLM_* / IMAGE_* 独立）
# ---------------------------------------------------------------------------
# 生产默认留空 = 同源 only（Docker 一体化部署下前端与 /api 经 nginx 同 origin，
#   浏览器不发 Origin 头，不触发预检，不需要放行任何跨域来源 —— 最严）。
# 仅在「浏览器直连后端 8000」联调时填逗号分隔来源：
#   CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# 留空时后端 allow_origins=[]，跨域请求一律被拦（同源不受影响）。
CORS_ALLOWED_ORIGINS=
